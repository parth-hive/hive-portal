NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — transactional email (rent/balance reminders, room-change & cleaning
# notices, lease-end heads-ups). NY tenants use Gmail instead (GMAIL_* below),
# which doesn't count against the Resend free tier.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
RESEND_REPLY_TO=
# Free-tier guard: once a cap is hit, the rest of the day's emails are queued and
# sent the next day (drained by the daily cron). Defaults: 90/day, 3000/month.
RESEND_DAILY_CAP=90
RESEND_MONTHLY_CAP=3000

# Agreement email drafts (see docs/AGREEMENTS_SETUP.md)
# Personal Gmail — New York agreements (no letterhead)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# M365 / Outlook work account — non-NY agreements (with letterhead)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REFRESH_TOKEN=
